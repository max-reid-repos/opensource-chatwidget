# Core server settings
PORT=3000
NODE_ENV=production
CHAT_TOKEN_SECRET=replace-with-a-long-random-secret
# Optional: enforce exact IP + User-Agent fingerprint matching.
# CHAT_STRICT_FINGERPRINT=true

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
